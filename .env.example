# Скопируй в .env и заполни.

# Какой провайдер использовать по умолчанию (openai | anthropic).
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6

POSTGRES_USER=landing
POSTGRES_PASSWORD=landing
POSTGRES_DB=landing

# Auth
JWT_SECRET=change-me-in-prod-please
JWT_EXPIRES_MINUTES=30

# Email (dev — Mailhog SMTP)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@landing-generator.local
