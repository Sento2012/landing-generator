# Скопируй в .env и заполни.

# Какой провайдер использовать по умолчанию (openai | anthropic).
# Можно переопределять per-request через тело POST /generations { provider: ... }
LLM_PROVIDER=openai

OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o

ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_MODEL=claude-sonnet-4-6

POSTGRES_USER=landing
POSTGRES_PASSWORD=landing
POSTGRES_DB=landing
